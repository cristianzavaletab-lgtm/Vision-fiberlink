# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================
# This is a sample connection string. Replace with your actual credentials.
DATABASE_URL="postgresql://user:password@localhost:5432/visioncontrol?schema=public"

# Supabase (Legacy variables, keep for backwards compatibility)
SUPABASE_URL="https://your-supabase-url.supabase.co"
SUPABASE_KEY="your-supabase-anon-key"

# Authentication
JWT_ACCESS_SECRET="your-super-secret-access-key-change-me"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-me"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"
BCRYPT_ROUNDS="10"

# ==========================================
# Google Drive - Screenshot Archive
# ==========================================
# OAuth2 credentials (Google Cloud Console -> APIs & Services -> Credentials)
GOOGLE_CLIENT_ID="96283704826-1dopsbi6e0j905o8bh2ijof0hpv220mp.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret-here"
# Redirect URI must match the one configured in Google Cloud Console
GOOGLE_REDIRECT_URI="http://localhost:3001/api/drive/callback"
# Folder ID from Google Drive (the part after /folders/ in the URL)
GOOGLE_DRIVE_FOLDER_ID="your-drive-folder-id"
# Upload interval in milliseconds (default: 120000 = 2 minutes)
SCREENSHOT_ARCHIVE_INTERVAL="120000"

PORT=3001
