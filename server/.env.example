# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================
# This is a sample connection string. Replace with your actual credentials.
DATABASE_URL="postgresql://user:password@localhost:5432/visioncontrol?schema=public"

# Supabase (Legacy variables, keep for backwards compatibility)
SUPABASE_URL="https://your-supabase-url.supabase.co"
SUPABASE_KEY="your-supabase-anon-key"

# Authentication
JWT_ACCESS_SECRET="your-super-secret-access-key-change-me"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-me"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"
BCRYPT_ROUNDS="10"

PORT=3001
