generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// Core Auth & Multi-tenant Models
// ------------------------------------------------------

model Company {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites    Site[]
  users    User[]
  devices  Device[]
}

model Site {
  id        String   @id @default(cuid())
  companyId String
  name      String
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  devices  Device[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  
  permissions Permission[] @relation("RolePermissions")
  users       User[]
}

model Permission {
  id          String   @id @default(cuid())
  action      String   @unique // e.g. "device:read", "remote:control"
  description String?

  roles       Role[]   @relation("RolePermissions")
}

model User {
  id        String   @id @default(cuid())
  companyId String
  roleId    String
  email     String   @unique
  password  String   // Hashed
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id])
  sessions  RemoteSession[]
  auditLogs AuditLog[]
}

// ------------------------------------------------------
// Devices & Agents
// ------------------------------------------------------

model Agent {
  id          String   @id @default(cuid())
  version     String
  status      String   @default("offline") // "online", "offline", "uninstalled"
  lastPingAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deviceId    String   @unique
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model Device {
  id          String   @id @default(cuid())
  companyId   String
  siteId      String?
  name        String
  os          String?
  macAddress  String?
  ipAddress   String?
  status      String   @default("offline")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site        Site?    @relation(fields: [siteId], references: [id])
  agent       Agent?
  
  metrics      DeviceMetric[]
  screenshots  Screenshot[]
  sessions     RemoteSession[]
  auditLogs    AuditLog[]
  incidents    Incident[]
  appSessions  AppSession[]
  bootSessions DeviceBootSession[]
  excelAuditLogs ExcelAuditLog[]
}

// ------------------------------------------------------
// Telemetry & Remote Actions
// ------------------------------------------------------

model DeviceMetric {
  id        String   @id @default(cuid())
  deviceId  String
  cpu       Float
  ram       Float
  activeApp String?
  createdAt DateTime @default(now())

  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, createdAt])
}

model Screenshot {
  id        String   @id @default(cuid())
  deviceId  String
  url       String   // Storage URL or bucket reference
  createdAt DateTime @default(now())

  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, createdAt])
}

model RemoteSession {
  id        String   @id @default(cuid())
  deviceId  String
  userId    String
  startedAt DateTime @default(now())
  endedAt   DateTime?
  type      String   // "remote_desktop", "terminal"

  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  companyId   String?  // Optional for system-wide logs
  userId      String?
  deviceId    String?
  action      String   // e.g. "USER_LOGIN", "REMOTE_RESTART"
  description String
  status      String   @default("success") // "success", "failed", "critical"
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])
  device      Device?  @relation(fields: [deviceId], references: [id])
}

model Incident {
  id          String   @id @default(cuid())
  deviceId    String
  type        String   // e.g. "offline", "high_cpu", "agent_error"
  severity    String   // "low", "medium", "high", "critical"
  status      String   @default("open") // "open", "reviewing", "resolved"
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  category    String   // "streaming", "agent", "security", "alerts"
  updatedAt   DateTime @updatedAt
}

// ------------------------------------------------------
// Activity Tracking - App Sessions & Boot Sessions
// ------------------------------------------------------

model AppSession {
  id        String    @id @default(cuid())
  deviceId  String
  appName   String
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  duration  Int?      // duration in seconds (computed on close)

  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, startedAt])
  @@index([deviceId, appName])
}

model DeviceBootSession {
  id        String    @id @default(cuid())
  deviceId  String
  bootAt    DateTime  @default(now())
  shutdownAt DateTime?
  totalSeconds Int?   // total uptime in seconds

  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, bootAt])
}

model AlertRule {
  id          String   @id @default(cuid())
  companyId   String?
  name        String
  type        String   // cpu_high, ram_high, offline_timeout, blocked_app
  metric      String?
  operator    String
  value       String
  duration    Int      @default(0) // seconds
  action      String   // notify, block, log, notify_and_log
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlockedApp {
  id          String   @id @default(cuid())
  companyId   String?
  name        String
  action      String   // kill, notify, log
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ------------------------------------------------------
// Excel Monitoring & Audit
// ------------------------------------------------------

model ExcelAuditLog {
  id          String   @id @default(cuid())
  deviceId    String
  fileName    String
  sheetName   String?
  action      String   // "add_row", "update_cell", "delete_row"
  details     String   // JSON stringified diff data
  naturalText String?  // Generated natural language text e.g. "Se registraron nuevas ventas por S/1000"
  createdAt   DateTime @default(now())

  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, createdAt])
}

enum SupportSessionStatus {
  PENDING
  WAITING_PERMISSION
  VIEW_ONLY
  CONTROL_REQUESTED
  CONTROL_ACTIVE
  REJECTED
  ENDED
  ERROR
}

model Machine {
  id                   String   @id
  name                 String
  hostname             String?
  localUser            String?
  companyArea          String?
  os                   String?
  ipAddress            String?
  status               String   @default("offline")
  agentVersion         String?
  remoteSupportEnabled Boolean  @default(false)
  remoteSupportActive  Boolean  @default(false)
  screenViewEnabled    Boolean  @default(false)
  remoteControlEnabled Boolean  @default(false)
  remoteControlMode    String   @default("request_permission")
  lastHeartbeatAt      DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  heartbeats           AgentHeartbeat[]
  supportSessions      SupportSession[]
  excelEvents          ExcelEvent[]

  @@index([status, lastHeartbeatAt])
}

model AgentHeartbeat {
  id             String   @id @default(cuid())
  machineId      String
  status         String
  cpu            Float?
  ram            Float?
  activeApp      String?
  remoteSupportActive Boolean @default(false)
  createdAt      DateTime @default(now())

  machine        Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([machineId, createdAt])
}

model SupportSession {
  id                      String               @id @default(cuid())
  machineId               String
  status                  SupportSessionStatus @default(PENDING)
  requestedBy             String
  viewPermissionStatus    String               @default("pending")
  controlPermissionStatus String               @default("not_requested")
  startedAt               DateTime             @default(now())
  endedAt                 DateTime?
  lastActivityAt          DateTime             @default(now())
  sessionTokenHash        String
  quality                 String               @default("medium")
  errorMessage            String?

  machine                 Machine              @relation(fields: [machineId], references: [id], onDelete: Cascade)
  events                  SupportEvent[]
  permissionRequests      SupportPermissionRequest[]
  alerts                  SupportAlert[]

  @@index([machineId, status])
  @@index([startedAt])
}

model SupportEvent {
  id        String   @id @default(cuid())
  sessionId String
  type      String
  message   String
  data      String?
  createdAt DateTime @default(now())

  session   SupportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model SupportPermissionRequest {
  id          String   @id @default(cuid())
  sessionId   String
  type        String
  status      String   @default("pending")
  requestedAt DateTime @default(now())
  answeredAt  DateTime?
  answeredBy  String?

  session     SupportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, type])
}

model SupportAlert {
  id                   String   @id @default(cuid())
  sessionId            String?
  machineId            String
  title                String
  message              String
  priority             String   @default("normal")
  status               String   @default("sent")
  requiresConfirmation Boolean  @default(true)
  createdAt            DateTime @default(now())
  confirmedAt          DateTime?
  rejectedAt           DateTime?

  session              SupportSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([machineId, createdAt])
}

model ExcelEvent {
  id             String   @id
  machineId      String
  eventType      String
  fileName       String
  filePath       String?
  sheetName      String?
  detectedAmount Float?
  currency       String   @default("PEN")
  actionSummary  String
  syncStatus     String   @default("pending")
  createdAt      DateTime @default(now())

  machine        Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([machineId, createdAt])
}
